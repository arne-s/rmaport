#KONSOLEH AREA START - PLEASE DO NOT EDIT MANUALLY BETWEEN THESE LINES
DirectoryIndex index.php
#KONSOLEH AREA END - PLEASE ADD MANUAL CHANGES BELOW
<IfModule mod_rewrite.c>
<IfModule mod_negotiation.c>
Options -MultiViews -Indexes
</IfModule>
RewriteEngine On
Header set Access-Control-Allow-Origin "*"
Header set Access-Control-Allow-Headers "origin, x-requested-with, content-type"
Header set Access-Control-Allow-Methods "GET, OPTIONS"
RewriteCond %{HTTP:Authorization} .
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} (.+)/$
RewriteRule ^ %1 [L,R=301]
RewriteCond %{HTTP:Upgrade} =websocket [NC]
RewriteCond %{HTTP:Connection} upgrade [NC]
RewriteRule ^ws/app/(.*)$ ws://127.0.0.1:8493/app/$1 [P,L]
RewriteRule ^ws/(.*)$ ws://127.0.0.1:8493/app/$1 [P,L]
RewriteCond %{HTTP:Upgrade} !=websocket [NC]
RewriteRule ^ws/app/(.*)$ http://127.0.0.1:8493/app/$1 [P,L]
RewriteRule ^ws/(.*)$ http://127.0.0.1:8493/app/$1 [P,L]
RewriteCond %{REQUEST_URI} !^/ws/ [NC]
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^ index.php [L]
</IfModule>
# Handle Authorization Header
# Redirect Trailing Slashes If Not A Folder...
# Reverb WebSocket proxy → 127.0.0.1:8493/app/{key}
# Echo with REVERB_WS_PATH=/ws connects to /ws/app/{key} (Pusher protocol)
# Direct test: /ws/{key} also works
# Send Requests To Front Controller...